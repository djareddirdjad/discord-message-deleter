{
  "manifest_version": 3,
  "name": "Discord Message Deleter",
  "version": "1.0.0",
  "description": "Bulk delete your own Discord messages from any channel or DM.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://discord.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
